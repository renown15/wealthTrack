# Production Environment Configuration (Raspberry Pi)
# Copy to .env.prod and fill in secure values before deploying
#
# Generate a SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Database
DB_PORT=5432
DB_USER=wealthtrack
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=wealthtrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
DB_VOLUME=wealthtrack_prod_pgdata
DB_CONTAINER=wealthtrack-db-prod

# Backend
BACKEND_PORT=8000
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_generate_with_command_above
BACKEND_CONTAINER=wealthtrack-backend-prod

# Frontend
# VITE_API_URL is baked into the frontend bundle at build time —
# set this to wherever your browser will reach the backend
FRONTEND_PORT=3000
VITE_API_URL=http://raspberrypi.local:8000
FRONTEND_CONTAINER=wealthtrack-frontend-prod
