# Production Environment Configuration Example
# Copy this file to .env.prod and set secrets via CI/CD environment variables
# DO NOT commit actual secrets to this file

# Database
DB_PORT=5432
DB_USER=wealthtrack_prod
DB_PASSWORD=${POSTGRES_PASSWORD}  # Set via CI/CD secrets
DB_NAME=wealthtrack_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}  # Set via CI/CD secrets

# Backend
BACKEND_PORT=8000
API_URL=https://api.wealthtrack.com
ENVIRONMENT=production
SECRET_KEY=${SECRET_KEY}  # Set via CI/CD secrets - must be strong random value

# Frontend
FRONTEND_PORT=80
VITE_API_URL=https://api.wealthtrack.com

# Container names
DB_CONTAINER=wealthtrack-db-prod
BACKEND_CONTAINER=wealthtrack-backend-prod
FRONTEND_CONTAINER=wealthtrack-frontend-prod

# Volume names
DB_VOLUME=wealthtrack-db-prod-volume
