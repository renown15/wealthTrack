{
  "name": "wealthtrack-frontend",
  "version": "1.0.0",
  "description": "WealthTrack Frontend - Strategic Wealth Management",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
