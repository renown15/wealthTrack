    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.1",
    "@vue/test-utils": "^2.4.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^8.56.0",
    "happy-dom": "^12.10.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.1.1"
