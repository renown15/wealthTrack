# Test Environment Configuration Example (Isolated for E2E Testing)
# Copy this file to .env.test and adjust values if needed (usually same as shown)

# Database
DB_PORT=5434
DB_USER=wealthtrack_test
DB_PASSWORD=test_password
DB_NAME=wealthtrack_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_postgres_password

# Backend
BACKEND_PORT=8001
API_URL=http://localhost:8001
ENVIRONMENT=test
SECRET_KEY=test-secret-key

# Frontend
FRONTEND_PORT=3001
VITE_API_URL=http://localhost:8001

# Container names
DB_CONTAINER=wealthtrack-db-test
BACKEND_CONTAINER=wealthtrack-backend-test
FRONTEND_CONTAINER=wealthtrack-frontend-test

# Volume names
DB_VOLUME=wealthtrack-db-test-volume
