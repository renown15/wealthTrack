# Development Environment Configuration Example
# Copy this file to .env.dev and adjust values for your setup

# Database
DB_PORT=5433
DB_USER=wealthtrack
DB_PASSWORD=wealthtrack_dev_password
DB_NAME=wealthtrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password

# Backend
BACKEND_PORT=8000
API_URL=http://localhost:8000
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production

# Frontend
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Container names
DB_CONTAINER=wealthtrack-db-dev
BACKEND_CONTAINER=wealthtrack-backend-dev
FRONTEND_CONTAINER=wealthtrack-frontend-dev
